# ---------- core ----------
ENV=local
API_PORT=8000
FRONT_PORT=5173

# ---------- postgres ----------
POSTGRES_DB=coach
POSTGRES_USER=coach
POSTGRES_PASSWORD=coach
POSTGRES_HOST=db
POSTGRES_PORT=5432
DATABASE_URL=postgresql+psycopg://coach:coach@db:5432/coach

# ---------- redis / queue ----------
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/0

# ---------- minio ----------
MINIO_ROOT_USER=minio
MINIO_ROOT_PASSWORD=minio123456
MINIO_ENDPOINT=http://minio:9000
MINIO_PUBLIC_ENDPOINT=http://localhost:9000
MINIO_BUCKET=coach


# ---------- embedding model ----------
EMBED_BASE_URL=http://host.docker.internal:8358
EMBED_MODEL=intfloat/multilingual-e5-large
EMBED_API_KEY=dummy

# ---------- LLM provider ----------
LLM_PROVIDER=openai_compatible
LLM_BASE_URL=http://host.docker.internal:8357/v1
LLM_API_KEY=dummy
LLM_MODEL=qwen2.5-vl-7b-awq